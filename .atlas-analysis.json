  "keyFeatures": [
    "Framework-agnostic React documentation framework",
    "Multiple UI component libraries (Radix UI, Base UI)",
    "Built-in MDX content processing and plugins",
    "Advanced search with Algolia, Orama, and built-in solutions",
    "OpenAPI documentation generation",
    "TypeScript API documentation generation",
    "Internationalization support",
    "Multiple layout options (docs, flux, notebook)",
    "Code syntax highlighting with Shiki",
    "Static site generation support",
    "CLI tool for scaffolding and component management"
  ],
  "publicApiSurface": [
    "fumadocs-core - Core library with source adapters, search, TOC, breadcrumbs",
    "fumadocs-ui - Default UI theme with Radix UI components",
    "@fumadocs/base-ui - Alternative UI with Base UI components",
    "fumadocs-mdx - Official MDX content source with bundler integrations",
    "fumadocs-openapi - OpenAPI spec to MDX documentation generator",
    "fumadocs-typescript - TypeScript API documentation generator",
    "fumadocs-twoslash - TypeScript code hover tooltips",
    "@fumadocs/cli - CLI tool for scaffolding and automation",
    "create-fumadocs-app - Project scaffolding tool",
    "@fumadocs/content-collections - Content Collections integration",
    "@fumadocs/mdx-remote - Remote MDX content support",
    "@fumadocs/obsidian - Obsidian vault integration"
  ]
